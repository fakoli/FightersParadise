/target
**/*.rs.bk
*.swp
*.swo
.DS_Store

# IDE
.idea/
.vscode/
*.iml

# Environment
.env
.env.*

# Claude Code local settings
.claude/settings.local.json

# Runtime state for scripts/fp.sh (detached game PID + log)
/.run

# MUGEN content files (not shipped with repo)
# The global block exists to keep third-party/Elecbyte binary assets out of the
# repo (clean-room guard). Two ORIGINAL, clean-room asset sets — the conformance
# character under assets/trainingdummy/ (authored from scratch, MIT — no Elecbyte
# content) and the common hit-spark effects under assets/data/ (fightfx.sff,
# audit #17 — also authored from scratch, MIT) — are SHIPPABLE, so their binary
# SFF/SND are explicitly un-ignored below. Do NOT add any third-party .sff/.snd here.
*.sff
*.snd
*.fnt
!/assets/trainingdummy/*.sff
!/assets/trainingdummy/*.snd
!/assets/data/*.sff

# Local-only sample MUGEN content for parser/integration testing
# (third-party assets, e.g. Elecbyte KFM CC BY-NC — never shipped)
/test-assets

# OS
Thumbs.db
