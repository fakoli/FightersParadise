/target
**/*.rs.bk
*.swp
*.swo
.DS_Store

# IDE
.idea/
.vscode/
*.iml

# Environment
.env
.env.*

# Claude Code local settings
.claude/settings.local.json

# Runtime state for scripts/fp.sh (detached game PID + log)
/.run

# MUGEN content files (not shipped with repo)
# The global block exists to keep third-party/Elecbyte binary assets out of the
# repo (clean-room guard). Three ORIGINAL, clean-room asset sets — the conformance
# character under assets/trainingdummy/ (authored from scratch, MIT — no Elecbyte
# content), the common hit-spark effects under assets/data/ (fightfx.sff,
# audit #17 — also authored from scratch, MIT), and the HUD bitmap font under
# assets/data/ (font.fnt, FL2b — authored from scratch, MIT; the only ASCII run is
# the required ElecbyteFnt magic) — are SHIPPABLE, so their binary SFF/SND/FNT are
# explicitly un-ignored below. Do NOT add any third-party .sff/.snd/.fnt here.
*.sff
*.snd
*.fnt
!/assets/trainingdummy/*.sff
!/assets/trainingdummy/*.snd
!/assets/data/*.sff
!/assets/data/*.fnt

# Local-only sample MUGEN content for parser/integration testing
# (third-party assets, e.g. Elecbyte KFM CC BY-NC — never shipped)
/test-assets

# Hash-keyed local IR cache (F034 T087) — generated, content-addressed cache of
# parsed character content; never tracked. $FP_CACHE_DIR may relocate it.
.fp-cache/

# OS
Thumbs.db
